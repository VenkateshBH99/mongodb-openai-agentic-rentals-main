/* ============================================================
   RentAI v2 — Styles
   ============================================================ */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #f5f7fa;
    color: #1a1a2e;
    line-height: 1.6;
}

.container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
}

/* ── Header ──────────────────────────────────────────── */
.header {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    padding: 0 24px;
    position: sticky;
    top: 0;
    z-index: 100;
}

.header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
}

.nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.4rem;
    font-weight: 700;
    color: #6366f1;
}

.nav-brand i { font-size: 1.5rem; }

.nav-menu {
    display: flex;
    gap: 8px;
}

.nav-link {
    text-decoration: none;
    color: #6b7280;
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.2s;
}

.nav-link:hover { color: #6366f1; background: #f0f0ff; }
.nav-link.active { color: #6366f1; background: #eef2ff; font-weight: 600; }

.model-badge {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
}

/* ── Hero ────────────────────────────────────────────── */
.hero {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 48px 0 40px;
    color: #fff;
    text-align: center;
}

.hero-title {
    font-size: 2.2rem;
    font-weight: 700;
    margin-bottom: 8px;
}

.hero-subtitle {
    font-size: 1rem;
    opacity: 0.9;
    margin-bottom: 28px;
}

.search-container { max-width: 700px; margin: 0 auto; }

.search-bar {
    display: flex;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.15);
}

.search-field {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 12px 16px;
    gap: 10px;
}

.search-field i { color: #9ca3af; }
.search-field input {
    border: none;
    outline: none;
    font-size: 0.95rem;
    font-family: inherit;
    width: 100%;
    color: #1a1a2e;
}

.search-btn {
    background: #6366f1;
    color: #fff;
    border: none;
    padding: 12px 24px;
    cursor: pointer;
    font-weight: 600;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s;
}

.search-btn:hover { background: #4f46e5; }

/* ── Filters ─────────────────────────────────────────── */
.filters-section {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    padding: 16px 0;
}

.filters {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    flex-wrap: wrap;
}

.filter-group label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    color: #6b7280;
    margin-bottom: 4px;
    text-transform: uppercase;
}

.filter-group select,
.filter-group input {
    padding: 8px 12px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 0.85rem;
    font-family: inherit;
    background: #fff;
    color: #1a1a2e;
}

.price-range {
    display: flex;
    align-items: center;
    gap: 6px;
}

.price-range input { width: 80px; }

.filter-apply-btn,
.filter-reset-btn {
    padding: 8px 18px;
    border-radius: 8px;
    border: none;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
}

.filter-apply-btn {
    background: #6366f1;
    color: #fff;
}

.filter-apply-btn:hover { background: #4f46e5; }

.filter-reset-btn {
    background: #f3f4f6;
    color: #6b7280;
}

.filter-reset-btn:hover { background: #e5e7eb; }

/* ── Results ─────────────────────────────────────────── */
.results-section { padding: 32px 0; }

.results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
}

.results-header h2 {
    font-size: 1.4rem;
    font-weight: 700;
}

.results-count {
    color: #6b7280;
    font-size: 0.9rem;
}

.results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
}

/* ── Rental Card ─────────────────────────────────────── */
.rental-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
}

.rental-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
}

.card-image {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: #e5e7eb;
}

.card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.no-image {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: #9ca3af;
    font-size: 2rem;
}

.card-badges {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
}

.card-badge {
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 700;
    backdrop-filter: blur(4px);
}

.rank-badge { background: rgba(99, 102, 241, 0.9); color: #fff; }
.score-badge { background: rgba(16, 185, 129, 0.9); color: #fff; }
.superhost-badge { background: rgba(245, 158, 11, 0.9); color: #fff; }

.card-body { padding: 16px; }

.card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.card-location {
    font-size: 0.85rem;
    color: #6b7280;
    margin-bottom: 8px;
}

.card-location i { margin-right: 4px; color: #6366f1; }

.card-details {
    display: flex;
    gap: 12px;
    font-size: 0.8rem;
    color: #9ca3af;
    margin-bottom: 12px;
}

.card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #f3f4f6;
    padding-top: 12px;
}

.card-price {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a1a2e;
}

.card-price small {
    font-size: 0.75rem;
    font-weight: 400;
    color: #9ca3af;
}

/* ── Pagination ──────────────────────────────────────── */
.pagination { margin-top: 32px; text-align: center; }

.pagination-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
}

.page-btn {
    width: 40px;
    height: 40px;
    border: 1px solid #d1d5db;
    background: #fff;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
}

.page-btn:hover { border-color: #6366f1; color: #6366f1; }
.page-btn.active { background: #6366f1; color: #fff; border-color: #6366f1; }

.page-info {
    margin-left: 12px;
    font-size: 0.85rem;
    color: #6b7280;
}

/* ── Loading / Empty ─────────────────────────────────── */
.loading-spinner {
    text-align: center;
    padding: 48px 0;
    color: #6b7280;
}

.spinner {
    width: 40px;
    height: 40px;
    border: 3px solid #e5e7eb;
    border-top: 3px solid #6366f1;
    border-radius: 50%;
    margin: 0 auto 12px;
    animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.empty-state {
    text-align: center;
    padding: 48px;
}

.empty-message {
    max-width: 500px;
    margin: 0 auto;
}

.empty-message i {
    font-size: 3rem;
    color: #d1d5db;
    margin-bottom: 16px;
}

.empty-message h3 {
    font-size: 1.2rem;
    margin-bottom: 8px;
}

.empty-message p {
    color: #6b7280;
    font-size: 0.9rem;
}

.error-state {
    text-align: center;
    padding: 48px;
    color: #ef4444;
}

.error-state i { font-size: 2rem; margin-bottom: 12px; }

/* ── Recommendations ─────────────────────────────────── */
.recommendations-section { padding: 32px 0; }

.recommendations-header {
    margin-bottom: 24px;
}

.rec-title-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
}

.rec-title-row h2 {
    font-size: 1.4rem;
    font-weight: 700;
}

.rec-badge {
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 700;
}

.rec-subtitle {
    color: #6b7280;
    font-size: 0.9rem;
}

.rec-input-row { margin-bottom: 24px; }

.rec-search {
    display: flex;
    align-items: center;
    gap: 12px;
    background: #fff;
    padding: 12px 16px;
    border-radius: 12px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    flex-wrap: wrap;
}

.rec-search i { color: #6366f1; font-size: 1.2rem; }

.rec-search input {
    flex: 1;
    min-width: 200px;
    border: none;
    outline: none;
    font-size: 0.95rem;
    font-family: inherit;
}

.rec-options {
    display: flex;
    align-items: center;
    gap: 6px;
}

.rec-options label {
    font-size: 0.8rem;
    color: #6b7280;
    font-weight: 600;
}

.rec-options select {
    padding: 6px 10px;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.85rem;
    font-family: inherit;
}

.btn-primary {
    background: #6366f1;
    color: #fff;
    border: none;
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.2s;
}

.btn-primary:hover { background: #4f46e5; }

/* User History Panel */
.user-history-panel {
    background: #fff;
    border-radius: 12px;
    padding: 16px 20px;
    margin-bottom: 24px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
}

.user-history-panel h3 {
    font-size: 1rem;
    margin-bottom: 12px;
    color: #6b7280;
}

.history-grid {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 8px;
}

.history-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 10px;
    background: #f9fafb;
    border-radius: 8px;
    padding: 8px 12px;
    cursor: pointer;
    transition: background 0.2s;
    min-width: 200px;
}

.history-item:hover { background: #eef2ff; }

.history-item img {
    width: 60px;
    height: 45px;
    object-fit: cover;
    border-radius: 6px;
}

.history-no-img {
    width: 60px;
    height: 45px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e5e7eb;
    border-radius: 6px;
    color: #9ca3af;
}

.history-info {
    display: flex;
    flex-direction: column;
}

.history-name {
    font-size: 0.8rem;
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.history-detail {
    font-size: 0.7rem;
    color: #9ca3af;
}

/* Recommendation Metadata */
.rec-meta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    background: #fff;
    padding: 12px 16px;
    border-radius: 10px;
    margin-bottom: 20px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
}

.meta-item {
    font-size: 0.85rem;
    color: #6b7280;
}

.meta-item strong { color: #1a1a2e; }

.meta-warn {
    color: #f59e0b;
    font-style: italic;
}

/* Model Architecture Diagram */
.model-arch-info {
    margin-top: 24px;
    background: #f9fafb;
    border-radius: 12px;
    padding: 20px;
}

.model-arch-info h4 {
    margin-bottom: 12px;
    font-size: 0.95rem;
    color: #6366f1;
}

.arch-diagram {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 8px;
}

.arch-node {
    background: #e0e7ff;
    color: #4338ca;
    padding: 6px 14px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.85rem;
}

.arch-node.out {
    background: #10b981;
    color: #fff;
}

.arch-arrow {
    color: #9ca3af;
    font-weight: 600;
    font-size: 1.2rem;
}

.arch-note {
    font-size: 0.8rem;
    color: #9ca3af;
    font-style: italic;
}

/* ── Stats ───────────────────────────────────────────── */
.stats-section { padding: 32px 0; }

.stats-section h2 {
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 24px;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 32px;
}

.stat-card {
    background: #fff;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
}

.stat-icon {
    font-size: 2rem;
    color: #6366f1;
    margin-bottom: 12px;
}

.stat-value {
    font-size: 1.8rem;
    font-weight: 700;
    color: #1a1a2e;
}

.stat-label {
    font-size: 0.85rem;
    color: #6b7280;
    margin-top: 4px;
}

.stats-details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
}

.stats-panel {
    background: #fff;
    border-radius: 12px;
    padding: 20px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
}

.stats-panel h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: #6366f1;
}

.stats-table {
    width: 100%;
    border-collapse: collapse;
}

.stats-table td {
    padding: 6px 0;
    font-size: 0.85rem;
    border-bottom: 1px solid #f3f4f6;
}

.stats-table td:last-child {
    text-align: right;
    font-weight: 600;
    color: #1a1a2e;
}

/* ── Modal ───────────────────────────────────────────── */
.modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
}

.modal-content {
    position: relative;
    background: #fff;
    border-radius: 16px;
    max-width: 800px;
    width: 90%;
    max-height: 85vh;
    overflow-y: auto;
    padding: 32px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
}

.modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 36px;
    height: 36px;
    border: none;
    background: #f3f4f6;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    transition: all 0.2s;
    z-index: 1;
}

.modal-close:hover { background: #e5e7eb; }

/* Detail View */
.detail-header {
    margin-bottom: 24px;
}

.detail-image {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 16px;
}

.detail-info h2 {
    font-size: 1.5rem;
    margin-bottom: 8px;
}

.detail-location {
    color: #6b7280;
    margin-bottom: 8px;
}

.detail-location i { color: #6366f1; }

.detail-price {
    font-size: 1.5rem;
    font-weight: 700;
}

.detail-price small {
    font-size: 0.85rem;
    font-weight: 400;
    color: #9ca3af;
}

.detail-grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.detail-section h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
    color: #6366f1;
}

.detail-section p {
    font-size: 0.9rem;
    color: #4b5563;
    line-height: 1.6;
}

.detail-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.detail-tag {
    background: #f3f4f6;
    padding: 6px 14px;
    border-radius: 8px;
    font-size: 0.85rem;
    color: #4b5563;
}

.detail-tag i { margin-right: 6px; color: #6366f1; }

.amenity-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
}

.amenity-tag {
    background: #eef2ff;
    color: #4338ca;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.8rem;
}

.amenity-tag.more {
    background: #f3f4f6;
    color: #6b7280;
}

.superhost-tag {
    background: #fef3c7;
    color: #92400e;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
}

/* ── Responsive ──────────────────────────────────────── */
@media (max-width: 768px) {
    .header .container { flex-wrap: wrap; gap: 8px; height: auto; padding: 12px 0; }
    .nav-menu { gap: 4px; }
    .hero-title { font-size: 1.6rem; }
    .search-bar { flex-direction: column; }
    .search-btn { justify-content: center; }
    .filters { flex-direction: column; }
    .results-grid { grid-template-columns: 1fr; }
    .rec-search { flex-direction: column; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
}
