/* ============================================================
   RentAI v2 — MLP Fusion Model Frontend
   Data source: Python Flask server (Normalized JSON + PyTorch)
   ============================================================ */

const API_BASE = ''; // Same origin — proxied through Elysia or direct to Flask

// ─────────────────────────────────────────────────────────────
// State
// ─────────────────────────────────────────────────────────────
let currentPage = 1;
let currentFilters = {};
let currentSearchQuery = '';
let activeTab = 'explore';

// ─────────────────────────────────────────────────────────────
// Init
// ─────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
    // Tab navigation
    document.querySelectorAll('.nav-link').forEach(link => {
        link.addEventListener('click', (e) => {
            e.preventDefault();
            const tab = link.dataset.tab;
            if (tab) switchTab(tab);
        });
    });

    loadRentals();
});

// ─────────────────────────────────────────────────────────────
// Tab Switching
// ─────────────────────────────────────────────────────────────
function switchTab(tab) {
    activeTab = tab;
    document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
    document.querySelector(`.nav-link[data-tab="${tab}"]`).classList.add('active');

    document.getElementById('exploreSection').style.display = tab === 'explore' ? '' : 'none';
    document.getElementById('filtersSection').style.display = tab === 'explore' ? '' : 'none';
    document.querySelector('.hero').style.display = tab === 'explore' ? '' : 'none';
    document.getElementById('recommendationsSection').style.display = tab === 'recommendations' ? '' : 'none';
    document.getElementById('statsSection').style.display = tab === 'stats' ? '' : 'none';

    if (tab === 'stats') loadStats();
}

// ─────────────────────────────────────────────────────────────
// Listings — Browse & Filter
// ─────────────────────────────────────────────────────────────
async function loadRentals(page = 1) {
    currentPage = page;
    const grid = document.getElementById('resultsGrid');
    const spinner = document.getElementById('loadingSpinner');
    const countEl = document.getElementById('resultsCount');
    const titleEl = document.getElementById('resultsTitle');

    spinner.style.display = '';
    grid.innerHTML = '';

    const params = new URLSearchParams({ page, limit: 20, ...currentFilters });
    if (currentSearchQuery) params.set('q', currentSearchQuery);

    const endpoint = currentSearchQuery ? '/search' : '/rentals';

    try {
        const res = await fetch(`${API_BASE}${endpoint}?${params}`);
        const data = await res.json();
        spinner.style.display = 'none';

        if (!data.success || !data.data.length) {
            grid.innerHTML = '<div class="empty-state"><div class="empty-message"><i class="fas fa-search"></i><h3>No rentals found</h3><p>Try adjusting your filters or search query.</p></div></div>';
            countEl.textContent = '0 results';
            document.getElementById('pagination').innerHTML = '';
            return;
        }

        titleEl.textContent = currentSearchQuery ? `Results for "${currentSearchQuery}"` : 'Available Rentals';
        countEl.textContent = `${data.total.toLocaleString()} results`;

        grid.innerHTML = data.data.map(listing => renderListingCard(listing)).join('');
        renderPagination(data.page, data.total_pages, data.total);
    } catch (err) {
        spinner.style.display = 'none';
        grid.innerHTML = `<div class="error-state"><i class="fas fa-exclamation-triangle"></i><p>Failed to load rentals: ${err.message}</p></div>`;
    }
}

function renderListingCard(listing, rank = null, score = null) {
    const img = listing.images?.picture_url || listing.image || '';
    const name = listing.name || 'Untitled';
    const price = listing.price != null ? `$${listing.price}` : 'N/A';
    const ptype = listing.property_type || '';
    const rtype = listing.room_type || '';
    const beds = listing.bedrooms != null ? `${listing.bedrooms} bed` : '';
    const bath = listing.bathrooms != null ? `${listing.bathrooms} bath` : '';
    const market = listing.address?.market || '';
    const country = listing.address?.country || '';
    const location = [market, country].filter(Boolean).join(', ');
    const lid = listing.listing_id;
    const superhost = listing.host?.host_is_superhost;

    let badges = '';
    if (rank != null) badges += `<span class="card-badge rank-badge">#${rank}</span>`;
    if (score != null) badges += `<span class="card-badge score-badge">${(score * 100).toFixed(1)}%</span>`;
    if (superhost) badges += `<span class="card-badge superhost-badge"><i class="fas fa-star"></i> Superhost</span>`;

    return `
        <div class="rental-card" onclick="showDetail(${lid})">
            <div class="card-image">
                ${img ? `<img src="${img}" alt="${name}" loading="lazy" onerror="this.src='https://via.placeholder.com/400x300?text=No+Image'" />` : '<div class="no-image"><i class="fas fa-image"></i></div>'}
                <div class="card-badges">${badges}</div>
            </div>
            <div class="card-body">
                <h3 class="card-title">${name}</h3>
                <p class="card-location"><i class="fas fa-map-marker-alt"></i> ${location || 'Unknown'}</p>
                <div class="card-details">
                    <span>${ptype}${rtype ? ' · ' + rtype : ''}</span>
                    <span>${[beds, bath].filter(Boolean).join(' · ')}</span>
                </div>
                <div class="card-footer">
                    <span class="card-price">${price}<small>/night</small></span>
                </div>
            </div>
        </div>
    `;
}

function renderPagination(page, totalPages, total) {
    const el = document.getElementById('pagination');
    if (totalPages <= 1) { el.innerHTML = ''; return; }

    let html = '<div class="pagination-controls">';
    if (page > 1) html += `<button onclick="loadRentals(${page - 1})" class="page-btn"><i class="fas fa-chevron-left"></i></button>`;

    const start = Math.max(1, page - 2);
    const end = Math.min(totalPages, page + 2);
    for (let i = start; i <= end; i++) {
        html += `<button onclick="loadRentals(${i})" class="page-btn ${i === page ? 'active' : ''}">${i}</button>`;
    }

    if (page < totalPages) html += `<button onclick="loadRentals(${page + 1})" class="page-btn"><i class="fas fa-chevron-right"></i></button>`;
    html += `<span class="page-info">Page ${page} of ${totalPages}</span></div>`;
    el.innerHTML = html;
}

// ─────────────────────────────────────────────────────────────
// Search
// ─────────────────────────────────────────────────────────────
function performSearch() {
    const q = document.getElementById('searchInput').value.trim();
    currentSearchQuery = q;
    currentPage = 1;

    // Also pick up filter values
    gatherFilters();
    loadRentals(1);
}

// ─────────────────────────────────────────────────────────────
// Filters
// ─────────────────────────────────────────────────────────────
function gatherFilters() {
    const f = {};
    const pt = document.getElementById('propertyType').value;
    const minP = document.getElementById('minPrice').value;
    const maxP = document.getElementById('maxPrice').value;
    const beds = document.getElementById('bedrooms').value;
    const sort = document.getElementById('sortBy').value;

    if (pt) f.property_type = pt;
    if (minP) f.min_price = minP;
    if (maxP) f.max_price = maxP;
    if (beds) f.bedrooms = beds;
    if (sort) f.sort = sort;

    currentFilters = f;
}

function applyFilters() {
    gatherFilters();
    currentPage = 1;
    loadRentals(1);
}

function resetFilters() {
    document.getElementById('propertyType').value = '';
    document.getElementById('minPrice').value = '';
    document.getElementById('maxPrice').value = '';
    document.getElementById('bedrooms').value = '';
    document.getElementById('sortBy').value = 'price_asc';
    document.getElementById('searchInput').value = '';
    currentFilters = {};
    currentSearchQuery = '';
    loadRentals(1);
}

// ─────────────────────────────────────────────────────────────
// Recommendations (MLP Fusion)
// ─────────────────────────────────────────────────────────────
async function loadRecommendations() {
    const userId = document.getElementById('recUserIdInput').value.trim();
    if (!userId) return;

    const topK = document.getElementById('recTopK').value;
    const grid = document.getElementById('recResultsGrid');
    const loading = document.getElementById('recLoading');
    const empty = document.getElementById('recEmptyState');
    const meta = document.getElementById('recMeta');
    const histPanel = document.getElementById('userHistoryPanel');

    empty.style.display = 'none';
    loading.style.display = '';
    grid.innerHTML = '';
    meta.style.display = 'none';
    histPanel.style.display = 'none';

    try {
        // Fetch recommendations and user history in parallel
        const [recRes, userRes] = await Promise.all([
            fetch(`${API_BASE}/recommendations/${encodeURIComponent(userId)}?top_k=${topK}`),
            fetch(`${API_BASE}/users/${encodeURIComponent(userId)}`),
        ]);

        const recData = await recRes.json();
        loading.style.display = 'none';

        // Show user history if available
        if (userRes.ok) {
            const userData = await userRes.json();
            if (userData.success && userData.history?.length) {
                histPanel.style.display = '';
                document.getElementById('userHistoryGrid').innerHTML = userData.history.map(h => `
                    <div class="history-item" onclick="showDetail(${h.listing_id})">
                        ${h.image ? `<img src="${h.image}" alt="${h.name}" onerror="this.src='https://via.placeholder.com/80x60?text=No+Img'" />` : '<div class="history-no-img"><i class="fas fa-image"></i></div>'}
                        <div class="history-info">
                            <span class="history-name">${h.name}</span>
                            <span class="history-detail">${h.property_type} · ${h.market || ''} · $${h.price || 'N/A'}</span>
                        </div>
                    </div>
                `).join('');
            }
        }

        if (!recData.success || !recData.data?.length) {
            empty.style.display = '';
            empty.querySelector('h3').textContent = 'No recommendations available';
            return;
        }

        // Show metadata
        meta.style.display = '';
        meta.innerHTML = `
            <div class="meta-item"><strong>Model:</strong> ${recData.model}</div>
            <div class="meta-item"><strong>Source:</strong> ${recData.source}</div>
            <div class="meta-item"><strong>User:</strong> ${recData.user_id || userId}</div>
            ${recData.interactions != null ? `<div class="meta-item"><strong>History:</strong> ${recData.interactions} interactions</div>` : ''}
            ${recData.message ? `<div class="meta-item meta-warn"><i class="fas fa-info-circle"></i> ${recData.message}</div>` : ''}
        `;

        grid.innerHTML = recData.data.map(item => {
            const listing = item.listing || item;
            return renderListingCard(listing, item.rank, item.score);
        }).join('');

    } catch (err) {
        loading.style.display = 'none';
        grid.innerHTML = `<div class="error-state"><i class="fas fa-exclamation-triangle"></i><p>Error: ${err.message}</p></div>`;
    }
}

// ─────────────────────────────────────────────────────────────
// Statistics
// ─────────────────────────────────────────────────────────────
async function loadStats() {
    const el = document.getElementById('statsContent');
    el.innerHTML = '<div class="loading-spinner"><div class="spinner"></div><p>Loading statistics...</p></div>';

    try {
        const res = await fetch(`${API_BASE}/stats`);
        const data = await res.json();

        el.innerHTML = `
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-building"></i></div>
                    <div class="stat-value">${data.total_listings?.toLocaleString()}</div>
                    <div class="stat-label">Total Listings</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-users"></i></div>
                    <div class="stat-value">${data.total_users?.toLocaleString()}</div>
                    <div class="stat-label">Total Users</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-handshake"></i></div>
                    <div class="stat-value">${data.total_interactions?.toLocaleString()}</div>
                    <div class="stat-label">Interactions</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon"><i class="fas fa-brain"></i></div>
                    <div class="stat-value">${data.listings_with_embeddings?.toLocaleString()}</div>
                    <div class="stat-label">Listings with Embeddings</div>
                </div>
            </div>

            <div class="stats-details">
                <div class="stats-panel">
                    <h3><i class="fas fa-dollar-sign"></i> Price Statistics</h3>
                    <table class="stats-table">
                        <tr><td>Minimum</td><td>$${data.price_stats?.min}</td></tr>
                        <tr><td>Maximum</td><td>$${data.price_stats?.max}</td></tr>
                        <tr><td>Average</td><td>$${data.price_stats?.avg}</td></tr>
                        <tr><td>Median</td><td>$${data.price_stats?.median}</td></tr>
                    </table>
                </div>

                <div class="stats-panel">
                    <h3><i class="fas fa-brain"></i> Model Architecture</h3>
                    <table class="stats-table">
                        <tr><td>Model</td><td>${data.model?.name}</td></tr>
                        <tr><td>Type</td><td>${data.model?.type}</td></tr>
                        <tr><td>Input Dim</td><td>${data.model?.input_dim}</td></tr>
                        <tr><td>Architecture</td><td>${data.model?.architecture}</td></tr>
                        <tr><td>Modalities</td><td>${data.model?.modalities?.join('<br>')}</td></tr>
                    </table>
                </div>

                <div class="stats-panel">
                    <h3><i class="fas fa-home"></i> Property Types</h3>
                    <table class="stats-table">
                        ${Object.entries(data.property_types || {}).map(([k, v]) =>
                            `<tr><td>${k}</td><td>${v}</td></tr>`
                        ).join('')}
                    </table>
                </div>

                <div class="stats-panel">
                    <h3><i class="fas fa-globe"></i> Top Markets</h3>
                    <table class="stats-table">
                        ${Object.entries(data.markets || {}).map(([k, v]) =>
                            `<tr><td>${k}</td><td>${v}</td></tr>`
                        ).join('')}
                    </table>
                </div>
            </div>
        `;
    } catch (err) {
        el.innerHTML = `<div class="error-state"><i class="fas fa-exclamation-triangle"></i><p>Failed to load stats: ${err.message}</p></div>`;
    }
}

// ─────────────────────────────────────────────────────────────
// Rental Detail Modal
// ─────────────────────────────────────────────────────────────
async function showDetail(listingId) {
    const modal = document.getElementById('rentalModal');
    const body = document.getElementById('modalBody');
    modal.style.display = '';

    body.innerHTML = '<div class="loading-spinner"><div class="spinner"></div><p>Loading details...</p></div>';

    try {
        const res = await fetch(`${API_BASE}/rentals/${listingId}`);
        const data = await res.json();

        if (!data.success) {
            body.innerHTML = '<p>Listing not found.</p>';
            return;
        }

        const l = data.data;
        const img = l.images?.picture_url || '';
        const location = [l.address?.market, l.address?.country].filter(Boolean).join(', ');
        const amenities = (l.amenities || []).slice(0, 20);

        body.innerHTML = `
            <div class="detail-header">
                ${img ? `<img src="${img}" alt="${l.name}" class="detail-image" onerror="this.src='https://via.placeholder.com/800x400?text=No+Image'" />` : ''}
                <div class="detail-info">
                    <h2>${l.name || 'Untitled'}</h2>
                    <p class="detail-location"><i class="fas fa-map-marker-alt"></i> ${location || 'Unknown location'}</p>
                    <div class="detail-price">$${l.price || 'N/A'}<small>/night</small></div>
                </div>
            </div>
            
            <div class="detail-grid">
                <div class="detail-section">
                    <h3>Property Details</h3>
                    <div class="detail-tags">
                        <span class="detail-tag"><i class="fas fa-home"></i> ${l.property_type || 'N/A'}</span>
                        <span class="detail-tag"><i class="fas fa-door-open"></i> ${l.room_type || 'N/A'}</span>
                        <span class="detail-tag"><i class="fas fa-bed"></i> ${l.bedrooms || 0} bedrooms</span>
                        <span class="detail-tag"><i class="fas fa-bath"></i> ${l.bathrooms || 0} bathrooms</span>
                        <span class="detail-tag"><i class="fas fa-users"></i> ${l.accommodates || 0} guests</span>
                        <span class="detail-tag"><i class="fas fa-bed"></i> ${l.beds || 0} beds</span>
                    </div>
                </div>

                ${l.summary ? `<div class="detail-section"><h3>Summary</h3><p>${l.summary}</p></div>` : ''}
                ${l.description ? `<div class="detail-section"><h3>Description</h3><p>${l.description.substring(0, 800)}${l.description.length > 800 ? '...' : ''}</p></div>` : ''}
                ${l.neighborhood_overview ? `<div class="detail-section"><h3>Neighborhood</h3><p>${l.neighborhood_overview}</p></div>` : ''}
                ${l.transit ? `<div class="detail-section"><h3>Transit</h3><p>${l.transit}</p></div>` : ''}

                ${amenities.length ? `
                    <div class="detail-section">
                        <h3>Amenities</h3>
                        <div class="amenity-tags">
                            ${amenities.map(a => `<span class="amenity-tag">${a}</span>`).join('')}
                            ${l.amenities.length > 20 ? `<span class="amenity-tag more">+${l.amenities.length - 20} more</span>` : ''}
                        </div>
                    </div>
                ` : ''}

                ${l.host?.host_name ? `
                    <div class="detail-section">
                        <h3>Host</h3>
                        <p><strong>${l.host.host_name}</strong> ${l.host.host_is_superhost ? '<span class="superhost-tag"><i class="fas fa-star"></i> Superhost</span>' : ''}</p>
                        ${l.host.host_location ? `<p><i class="fas fa-map-marker-alt"></i> ${l.host.host_location}</p>` : ''}
                    </div>
                ` : ''}

                <div class="detail-section">
                    <h3>Booking</h3>
                    <div class="detail-tags">
                        <span class="detail-tag"><i class="fas fa-calendar-alt"></i> Min ${l.minimum_nights || 1} nights</span>
                        <span class="detail-tag"><i class="fas fa-calendar-alt"></i> Max ${l.maximum_nights || 'N/A'} nights</span>
                        <span class="detail-tag"><i class="fas fa-ban"></i> ${l.cancellation_policy || 'N/A'}</span>
                    </div>
                </div>

                ${l.listing_url ? `<div class="detail-section"><a href="${l.listing_url}" target="_blank" rel="noopener noreferrer" class="btn-primary"><i class="fas fa-external-link-alt"></i> View on Airbnb</a></div>` : ''}
            </div>
        `;
    } catch (err) {
        body.innerHTML = `<p>Error loading details: ${err.message}</p>`;
    }
}

function closeModal() {
    document.getElementById('rentalModal').style.display = 'none';
}

// Close modal on Escape
document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
});
